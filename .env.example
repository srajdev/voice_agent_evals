# Copy this file to .env and fill in your values
# cp .env.example .env

# Required: Anthropic API key for LLM-judge metrics
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant....

# Optional: override the default Claude model used for evaluation
# VOICE_EVALS_MODEL=claude-sonnet-4-6

# Optional: Whisper model size used by the API server (tiny/base/small/medium)
# WHISPER_MODEL=base
